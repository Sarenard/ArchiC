u32 fastmul(u32 a, u32 b) {
    u32 tot = 0;

    while (a) {
        if (a && 1) {
            tot = tot + b;
        }

        a = a >> 1;
        b = b << 1;
    }

    return tot;
}

void plot(u32 x, u32 y, u32 color) {
    u32 mem = 0x01000000;

    mem = mem + fastmul(x, 4);
    mem = mem + fastmul(y, fastmul(640, 4));

    *mem = color;
}

// for drawing chars
void draw(u32 x, u32 y, u32 thing, u32 color) {
    for (u32 i = 0; i < 4; i = i + 1) {
        for (u32 j = 0; j < 8; j = j + 1) {
            if (thing && 1) {
                plot(x + 8 - j, y + i, color);
            }
            thing = thing >> 1;
        }
    }
}

