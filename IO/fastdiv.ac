void main() {
    u32 a = 15;
    u32 b = 4;

    u32 q = 0;
    u32 r = a;

    u32 i = 0;
    while ((b << (i + 1)) <= r) {
        i = i + 1;
    }

    while (i > 0) {
        if (r >= (b << i)) {
            r = r - (b << i);
            q = (1 << i) | q;
        }
        i = i - 1;
    }
    if (r >= (b << i)) {
        r = r - (b << i);
        q = (1 << i) | q;
    }
    i = i - 1;

    u32 ok = (q != 3) | (r != 3);

    return ok;
}